#!/bin/bash

function google() {
    BASE_URL="https://duckduckgo.com/?q="
    SEARCH_STRING=$(sed 's/ /+/g' <<< $@)
    w3m ${BASE_URL}${SEARCH_STRING}
}

function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	command yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
	rm -f -- "$tmp"
}
